{
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/analyze-expert.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/users.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/knowledge.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/software.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/auth.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/reset.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/analyze-video.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/ratings.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/style-preview.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/rollback.js": {
      "maxDuration": 30,
      "memory": 256
    }
  },
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}